{
  "name": "electron-vue-theme-template",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently --kill-others \"vite\" \"wait-on http://localhost:5174 && electron .\"",
    "electron:pack": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.example.electronvuetheme",
    "productName": "ElectronVueTheme",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "files": [
      "electron/**/*",
      "dist/**/*"
    ],
    "asar": true
  },
  "dependencies": {
    "pinia": "^2.2.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  }
}
